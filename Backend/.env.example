# Configuración de entorno de Urbalert Backend
# Copiar este archivo como .env y ajustar los valores

SECRET_KEY=django-insecure-cambia-esta-clave-en-produccion-urbalert-2026
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Motor de base de datos: sqlite | postgres
DB_ENGINE=sqlite

# Configuración PostgreSQL (sólo si DB_ENGINE=postgres)
DB_NAME=urbalert
DB_USER=urbalert
DB_PASSWORD=urbalert
DB_HOST=localhost
DB_PORT=5432

# CORS - orígenes permitidos del frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─────────── Producción (Railway) ───────────
# En Railway, en vez de DB_* se usa una sola variable DATABASE_URL.
# Railway la provee al referenciar el servicio de PostgreSQL:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
#
# Variables recomendadas en Railway:
#   DEBUG=False
#   SECRET_KEY=<una-clave-larga-y-secreta>
#   ALLOWED_HOSTS=<tu-app>.up.railway.app
#   CORS_ALLOWED_ORIGINS=https://<tu-frontend>.vercel.app
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
